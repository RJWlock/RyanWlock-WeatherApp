@page "/forecast/{Latitude}/{Longitude}/{StationId}"
@rendermode InteractiveServer

@using CanAmWeatherApp.Services
@using CanAmWeatherApp.Models 
@using System.Globalization
@inject WeatherService WeatherService
@inject NavigationManager NavigationManager

<PageTitle>Forecast</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">

    <MudButton Variant="Variant.Outlined"
               Color="Color.Primary"
               Class="mb-4"
               OnClick="@(() => NavigationManager.NavigateTo("/weather"))">
        Back to Search
    </MudButton>

    @if (isLoadingForecast)
    {
        <MudProgressCircular Indeterminate="true" Class="my-4" />
    }

    @if (!string.IsNullOrWhiteSpace(forecastError))
    {
        <MudAlert Severity="Severity.Error" Class="my-4">
            @forecastError
        </MudAlert>
    }

    @if (!string.IsNullOrWhiteSpace(forecastEmpty))
    {
        <MudAlert Severity="Severity.Info" Class="my-4">
            @forecastEmpty
        </MudAlert>
    }

    @if (forecastPeriods is not null && forecastPeriods.Count > 0)
    {
        var current = selectedPeriod ?? forecastPeriods.First();
        var dailyCards = GetDailyCards().ToList();
        var selectedHourly = GetSelectedDayHourlyPeriods().ToList();

        <MudPaper Class="pa-5 mb-5 rounded-xl weather-dashboard" Elevation="4">
            <MudGrid align-items="AlignItems.Center" Class="mb-5">
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h5" Class="location-title">
                        @StationId
                    </MudText>
                </MudItem>

                <MudItem xs="12" md="6" Class="weather-header">
                    <MudText Typo="Typo.h3">Weather</MudText>
                    <MudText Typo="Typo.h5" Class="muted-text">@current.Name</MudText>
                    <MudText Typo="Typo.h6" Class="muted-text">@current.ShortForecast</MudText>
                </MudItem>
            </MudGrid>

            <MudGrid align-items="AlignItems.Center" Class="mb-5">
                <MudItem xs="12" md="6">
                    <div class="current-summary">
                        <div class="big-icon">@GetWeatherIcon(current.ShortForecast)</div>
                        <div class="temp-row">
                            <div class="current-temp">
                                @selectedPeriod.Temperature°
                            </div>

                            @if (GetLowForCurrentPeriod() is not null)
                            {
                                <div class="current-low">
                                    @GetLowForCurrentPeriod()°
                                </div>
                            }
                        </div>
                        <div class="unit-text">@current.TemperatureUnit</div>
                    </div>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4 rounded-xl details-card" Elevation="0">
                        <MudText Typo="Typo.h6" Class="mb-2">Forecast Details</MudText>
                        <MudText Typo="Typo.body1">@current.DetailedForecast</MudText>
                        @if (!string.IsNullOrWhiteSpace(current.WindSpeed))
                        {
                            <MudText Typo="Typo.body2" Class="mt-2 muted-text">
                                Wind: @current.WindSpeed @current.WindDirection
                            </MudText>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudText Typo="Typo.h6" Class="mb-2">24 Hour Forecast</MudText>
            <div class="tab-underline"></div>

            @if (selectedHourly.Count > 0)
            {
                <div class="hourly-card-section @(showAllHourly ? "hourly-card-section-expanded" : "hourly-card-section-collapsed")">
                    @foreach (var hour in selectedHourly)
                    {
                        <MudPaper Class="hourly-card" Elevation="0">
                            <MudText Typo="Typo.subtitle2" Class="hourly-time">
                                @hour.StartTime.ToString("h tt", CultureInfo.InvariantCulture).ToLower().Replace(" ", "")
                            </MudText>
                            <MudText Class="hourly-icon">@GetWeatherIcon(hour.ShortForecast)</MudText>
                            <MudText Typo="Typo.h6">@hour.Temperature°</MudText>
                            <MudText Typo="Typo.caption" Class="muted-text hourly-summary">
                                @hour.ShortForecast
                            </MudText>
                        </MudPaper>
                    }
                </div>

                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Class="mt-3"
                           OnClick="ToggleHourlyCards">
                    @(showAllHourly ? "Show Less" : "Show More")
                </MudButton>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Class="my-4">
                    No hourly periods were returned for the selected day.
                </MudAlert>
            }

            <div class="daily-card-row mt-5">
                @foreach (var card in dailyCards)
                {
                    <MudPaper Class="@GetDailyCardClass(card.Period)"
                              Elevation="0"
                              @onclick="@(() => SelectPeriod(card.Period))">
                        <MudText Typo="Typo.h6">@GetDayLabel(card.Period)</MudText>
                        <MudText Class="small-weather-icon my-2">@GetWeatherIcon(card.Period.ShortForecast)</MudText>
                        <MudText Typo="Typo.h6">
                            @card.Period.Temperature°
                            @if (card.LowTemperature is not null)
                            {
                                <span class="low-temp">@card.LowTemperature°</span>
                            }
                        </MudText>
                    </MudPaper>
                }
            </div>
        </MudPaper>
    }

</MudContainer>