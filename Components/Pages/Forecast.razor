@page "/forecast/{Latitude}/{Longitude}/{StationId}"
@rendermode InteractiveServer

@using CanAmWeatherApp.Services
@using CanAmWeatherApp.Models 
@using System.Globalization
@inject WeatherService WeatherService
@inject NavigationManager NavigationManager

<PageTitle>Forecast</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">

    <MudButton Variant="Variant.Outlined"
               Color="Color.Primary"
               Class="mb-4"
               OnClick="@(() => NavigationManager.NavigateTo("/weather"))">
        Back to Search
    </MudButton>

    @if (isLoadingForecast)
    {
        <MudProgressCircular Indeterminate="true" Class="my-4" />
    }

    @if (!string.IsNullOrWhiteSpace(forecastError))
    {
        <MudAlert Severity="Severity.Error" Class="my-4">
            @forecastError
        </MudAlert>
    }

    @if (!string.IsNullOrWhiteSpace(forecastEmpty))
    {
        <MudAlert Severity="Severity.Info" Class="my-4">
            @forecastEmpty
        </MudAlert>
    }

    @if (forecastPeriods is not null && forecastPeriods.Count > 0)
    {
        var current = selectedPeriod ?? forecastPeriods.First();
        var dailyCards = GetDailyCards().ToList();
        var selectedHourly = GetSelectedDayHourlyPeriods().ToList();

        <MudPaper Class="pa-5 mb-5 rounded-xl weather-dashboard" Elevation="4">
            <MudGrid align-items="AlignItems.Center" Class="mb-5">
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h5" Class="location-title">
                        @StationId
                    </MudText>
                </MudItem>

                <MudItem xs="12" md="6" Class="weather-header">
                    <MudText Typo="Typo.h3">Weather</MudText>
                    <MudText Typo="Typo.h5" Class="muted-text">@current.Name</MudText>
                    <MudText Typo="Typo.h6" Class="muted-text">@current.ShortForecast</MudText>
                </MudItem>
            </MudGrid>

            <MudGrid align-items="AlignItems.Center" Class="mb-5">
                <MudItem xs="12" md="6">
                    <div class="current-summary">
                        <div class="big-icon">@GetWeatherIcon(current)</div>
                        <div class="temp-row">
                            <div class="current-temp">
                                @current.Temperature°
                            </div>

                            @if (GetLowForCurrentPeriod() is not null)
                            {
                                <div class="current-low">
                                    @GetLowForCurrentPeriod()°
                                </div>
                            }
                        </div>
                        <div class="unit-text">@current.TemperatureUnit</div>
                    </div>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4 rounded-xl details-card" Elevation="0">
                        <MudText Typo="Typo.h6" Class="mb-2">Forecast Details</MudText>
                        <MudText Typo="Typo.body1">@current.DetailedForecast</MudText>
                        @if (!string.IsNullOrWhiteSpace(current.WindSpeed))
                        {
                            <MudText Typo="Typo.body2" Class="mt-2 muted-text">
                                Wind: @current.WindSpeed @current.WindDirection
                            </MudText>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudText Typo="Typo.h6" Class="mb-2">24 Hour Forecast</MudText>
            <div class="tab-underline"></div>

            @if (selectedHourly.Count > 0)
            {
                <div class="hourly-card-section @(showAllHourly ? "hourly-card-section-expanded" : "hourly-card-section-collapsed")">
                    @foreach (var hour in selectedHourly)
                    {
                        <MudPaper Class="hourly-card" Elevation="0">
                            <MudText Typo="Typo.subtitle2" Class="hourly-time">
                                @hour.StartTime.ToString("h tt", CultureInfo.InvariantCulture).ToLower().Replace(" ", "")
                            </MudText>
                            <div class="hourly-icon">
                                @if (!hour.IsDaytime &&
                                    hour.ShortForecast.Contains("Cloud", StringComparison.OrdinalIgnoreCase))
                                {
                                    <div class="moon-cloud-icon">
                                        <span class="moon">🌙</span>
                                        <span class="cloud">☁️</span>
                                    </div>
                                }
                                else
                                {
                                    @GetWeatherIcon(hour)
                                }
                            </div>
                            <MudText Typo="Typo.h6">@hour.Temperature°</MudText>
                            <MudText Typo="Typo.caption" Class="muted-text hourly-summary">
                                @hour.ShortForecast
                            </MudText>
                        </MudPaper>
                    }
                </div>

                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Class="mt-3"
                           OnClick="ToggleHourlyCards">
                    @(showAllHourly ? "Show Less" : "Show More")
                </MudButton>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Class="my-4">
                    No hourly periods were returned for the selected day.
                </MudAlert>
            }

            <div class="daily-card-row mt-5">
                @foreach (var card in dailyCards)
                {
                    <MudPaper Class="@GetDailyCardClass(card.Period)"
                              Elevation="0"
                              @onclick="@(() => SelectPeriod(card.Period))">
                        <MudText Typo="Typo.h6">@GetDayLabel(card.Period)</MudText>
                        <MudText Class="small-weather-icon my-2">@GetWeatherIcon(card.Period)</MudText>
                        <MudText Typo="Typo.h6">
                            @card.Period.Temperature°
                            @if (card.LowTemperature is not null)
                            {
                                <span class="low-temp">@card.LowTemperature°</span>
                            }
                        </MudText>
                    </MudPaper>
                }
            </div>
        </MudPaper>
    }

</MudContainer>

<style>
    .weather-dashboard {
        background: #202124;
        color: white;
    }

    .location-title {
        font-weight: 700;
    }

    .weather-header {
        text-align: right;
    }

    .muted-text {
        color: rgba(255, 255, 255, 0.70);
    }

    .current-summary {
        display: flex;
        align-items: center;
        gap: 18px;
    }

    .big-icon {
        font-size: 72px;
        line-height: 1;
    }

    .current-temp {
        font-size: 86px;
        line-height: 1;
        font-weight: 300;
    }

    .unit-text {
        font-size: 28px;
        align-self: flex-start;
        margin-top: 10px;
        color: rgba(255, 255, 255, 0.85);
    }

    .details-card {
        background: rgba(255, 255, 255, 0.07);
        color: white;
    }

    .tab-underline {
        width: 140px;
        height: 4px;
        background: #f6c945;
        margin-bottom: 24px;
    }

    .hourly-card-section {
        display: flex;
        gap: 12px;
        padding-bottom: 6px;
    }

    .hourly-card-section-collapsed {
        flex-wrap: nowrap;
        overflow: hidden;
    }

    .hourly-card-section-expanded {
        flex-wrap: wrap;
        overflow: visible;
    }

    .hourly-card {
        background: rgba(255, 255, 255, 0.07);
        color: white;
        flex: 0 0 118px;
        min-height: 142px;
        text-align: center;
        border-radius: 16px;
        padding: 12px;
    }

    .hourly-time {
        color: rgba(255, 255, 255, 0.75);
    }

    .hourly-icon {
        font-size: 30px;
        margin: 8px 0;
    }

    .hourly-summary {
        display: block;
        line-height: 1.2;
        margin-top: 4px;
    }

    .daily-card-row {
        display: flex;
        gap: 12px;
        overflow-x: auto;
        padding-bottom: 6px;
    }

    .daily-card {
        background: transparent;
        color: white;
        min-width: 128px;
        min-height: 160px;
        text-align: center;
        cursor: pointer;
        border-radius: 18px;
        padding: 16px;
        transition: background-color 0.15s ease-in-out;
    }

        .daily-card:hover,
        .daily-card-selected {
            background: rgba(255, 255, 255, 0.10);
        }

    .small-weather-icon {
        font-size: 42px;
        text-align: center;
    }

    .low-temp {
        color: rgba(255, 255, 255, 0.55);
        font-size: 0.85em;
        margin-left: 6px;
    }

    @@media (max-width: 960px) {
        .weather-header {
            text-align: left;
        }

        .current-temp {
            font-size: 64px;
        }
    }
    .temp-row {
        display: flex;
        align-items: flex-end;
        gap: 12px;
    }

    .current-low {
        font-size: 32px;
        font-weight: 400;
        color: rgba(255,255,255,.45);
        padding-bottom: 10px;
    }

    .moon-cloud-icon {
        position: relative;
        width: 42px;
        height: 42px;
        margin: 0 auto;
    }

    .moon {
        position: absolute;
        left: 4px;
        top: 2px;
        font-size: 26px;
        z-index: 1;
    }

    .cloud {
        position: absolute;
        left: 12px;
        top: 12px;
        font-size: 24px;
        z-index: 2;
    }
</style>