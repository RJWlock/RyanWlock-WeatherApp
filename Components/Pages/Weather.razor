@page "/weather"
@rendermode InteractiveServer

@using CanAmWeatherApp.Services
@inject WeatherService WeatherService

<PageTitle>Weather</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">
    CanAm Weather App
</MudText>

<MudText Typo="Typo.body1" Class="mb-4">
    Enter a U.S. state abbreviation to load forecast zones.
</MudText>

<MudStack Row="true" Spacing="2" Class="mb-4">
    <MudTextField @bind-Value="stateInput"
                  Label="State"
                  Placeholder="CO"
                  Variant="Variant.Outlined" />

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               OnClick="SearchZones">
        Search
    </MudButton>
</MudStack>

@if (isLoadingZones)
{
    <MudProgressCircular Indeterminate="true" Class="my-4" />
}

@if (!string.IsNullOrWhiteSpace(zonesError))
{
    <MudAlert Severity="Severity.Error" Class="my-4">
        @zonesError
    </MudAlert>
}

@if (!string.IsNullOrWhiteSpace(zonesEmpty))
{
    <MudAlert Severity="Severity.Info" Class="my-4">
        @zonesEmpty
    </MudAlert>
}

@if (zones is not null)
{
    <MudTable Items="zones" Hover="true">
        <HeaderContent>
            <MudTh>Zone ID</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Action</MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd DataLabel="Zone ID">@context.Properties.Id</MudTd>
            <MudTd DataLabel="Name">@context.Properties.Name</MudTd>
            <MudTd>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           OnClick="@(() => SelectZone(context.Properties.Id))">
                    Select
                </MudButton>
            </MudTd>
        </RowTemplate>

        <ChildRowContent>
            @if (selectedZoneId == context.Properties.Id)
            {
                <MudTd colSpan="3">
                    <MudPaper Class="pa-4 my-2" Elevation="0">
                        <MudText Typo="Typo.h6" Class="mb-2">
                            Stations for @context.Properties.Id
                        </MudText>

                        @if (isLoadingStations)
                        {
                            <MudProgressCircular Indeterminate="true" Class="my-2" />
                        }

                        @if (!string.IsNullOrWhiteSpace(stationsError))
                        {
                            <MudAlert Severity="Severity.Error" Class="my-2">
                                @stationsError
                            </MudAlert>
                        }

                        @if (!string.IsNullOrWhiteSpace(stationsEmpty))
                        {
                            <MudAlert Severity="Severity.Info" Class="my-2">
                                @stationsEmpty
                            </MudAlert>
                        }

                        @if (stations is not null)
                        {
                            <MudTable Items="stations" Dense="true" Hover="true">
                                <HeaderContent>
                                    <MudTh>Station ID</MudTh>
                                    <MudTh>Name</MudTh>
                                    <MudTh>Action</MudTh>
                                </HeaderContent>

                                <RowTemplate Context="station">
                                    <MudTd>@station.Properties.StationIdentifier</MudTd>
                                    <MudTd>@station.Properties.Name</MudTd>
                                    <MudTd>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Secondary"
                                                   OnClick="@(() => SelectStation(station))">
                                            Forecast
                                        </MudButton>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }

                        @if (isLoadingForecast)
                        {
                            <MudProgressCircular Indeterminate="true" Class="my-4" />
                        }

                        @if (!string.IsNullOrWhiteSpace(forecastError))
                        {
                            <MudAlert Severity="Severity.Error" Class="my-4">
                                @forecastError
                            </MudAlert>
                        }

                        @if (!string.IsNullOrWhiteSpace(forecastEmpty))
                        {
                            <MudAlert Severity="Severity.Info" Class="my-4">
                                @forecastEmpty
                            </MudAlert>
                        }

                        @if (forecastPeriods is not null)
                        {
                            <MudText Typo="Typo.h6" Class="mt-4 mb-2">
                                Forecast for @selectedStationId
                            </MudText>

                            <MudTable Items="forecastPeriods" Dense="true" Hover="true">
                                <HeaderContent>
                                    <MudTh>Period</MudTh>
                                    <MudTh>Temperature</MudTh>
                                    <MudTh>Short Forecast</MudTh>
                                    <MudTh>Details</MudTh>
                                </HeaderContent>

                                <RowTemplate Context="period">
                                    <MudTd>@period.Name</MudTd>
                                    <MudTd>@period.Temperature °@period.TemperatureUnit</MudTd>
                                    <MudTd>@period.ShortForecast</MudTd>
                                    <MudTd>@period.DetailedForecast</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudPaper>
                </MudTd>
            }
        </ChildRowContent>
    </MudTable>
}

@code {
    private string stateInput = "";

    private List<ZoneFeature>? zones;
    private List<StationFeature>? stations;
    private List<ForecastPeriod>? forecastPeriods;

    private string? selectedZoneId;
    private string? selectedStationId;

    private bool isLoadingZones;
    private bool isLoadingStations;
    private bool isLoadingForecast;

    private string? zonesError;
    private string? zonesEmpty;

    private string? stationsError;
    private string? stationsEmpty;

    private string? forecastError;
    private string? forecastEmpty;

    private async Task SearchZones()
    {
        zonesError = null;
        zonesEmpty = null;
        stationsError = null;
        stationsEmpty = null;
        forecastError = null;
        forecastEmpty = null;

        zones = null;
        stations = null;
        selectedZoneId = null;
        forecastPeriods = null;
        selectedStationId = null;

        if (string.IsNullOrWhiteSpace(stateInput) || stateInput.Trim().Length != 2)
        {
            zonesError = "Please enter a valid 2-letter state code, such as CO, TX, or CA.";
            return;
        }

        isLoadingZones = true;

        try
        {
            var result = await WeatherService.GetForecastZonesByStateAsync(stateInput.Trim().ToUpper());
            zones = result?.Features;

            if (zones == null || zones.Count == 0)
            {
                zonesEmpty = $"No forecast zones found for '{stateInput}'.";
            }
        }
        catch (Exception ex)
        {
            zonesError = $"Could not load zones. {ex.Message}";
        }
        finally
        {
            isLoadingZones = false;
        }
    }

    private async Task SelectZone(string zoneId)
    {
        selectedZoneId = zoneId;

        stationsError = null;
        stationsEmpty = null;
        forecastError = null;
        forecastEmpty = null;

        stations = null;
        forecastPeriods = null;
        selectedStationId = null;

        isLoadingStations = true;

        try
        {
            var result = await WeatherService.GetStationsByZoneAsync(zoneId);
            stations = result?.Features;

            if (stations == null || stations.Count == 0)
            {
                stationsEmpty = "No stations found for this zone.";
            }
        }
        catch (Exception ex)
        {
            stationsError = $"Failed to load stations. {ex.Message}";
        }
        finally
        {
            isLoadingStations = false;
        }
    }

    private async Task SelectStation(StationFeature station)
    {
        selectedStationId = station.Properties.StationIdentifier;

        forecastError = null;
        forecastEmpty = null;
        forecastPeriods = null;

        isLoadingForecast = true;

        try
        {
            var longitude = station.Geometry.Coordinates[0];
            var latitude = station.Geometry.Coordinates[1];

            var pointData = await WeatherService.GetPointDataAsync(latitude, longitude);

            if (string.IsNullOrWhiteSpace(pointData?.Properties.Forecast))
            {
                forecastEmpty = "No forecast endpoint was available for this station.";
                return;
            }

            var forecast = await WeatherService.GetForecastAsync(pointData.Properties.Forecast);
            forecastPeriods = forecast?.Properties.Periods;

            if (forecastPeriods == null || forecastPeriods.Count == 0)
            {
                forecastEmpty = "No forecast periods were returned for this station.";
            }
        }
        catch (Exception ex)
        {
            forecastError = $"Failed to load forecast. {ex.Message}";
        }
        finally
        {
            isLoadingForecast = false;
        }
    }
}